<Window x:Class="BookStoreApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BookStore Library - Login"
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="BookStore Library Login"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Username"/>
            <TextBox x:Name="txtUsername" Margin="0,5,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5,0,20" Height="30" Padding="5"/>

            <Button Content="Login"
                    Height="35"
                    Click="btnLogin_Click"/>

            <TextBlock x:Name="txtError"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>