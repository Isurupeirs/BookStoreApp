<Window x:Class="BookStoreApp.Views.StaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BookStore Library - Staff"
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Staff Name and Location -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="lblStaffName" FontSize="16" FontWeight="Bold"/>
            <TextBlock x:Name="lblLocation" Foreground="Gray"/>
        </StackPanel>

        <!-- Books Table Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Book Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtBookName" Width="150" Height="28" Padding="3"/>
            <TextBlock Text="Copies:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="txtCopies" Width="60" Height="28" Padding="3"/>
            <TextBlock Text="Price:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="txtPrice" Width="80" Height="28" Padding="3"/>
            <Button Content="Add" Width="60" Height="28" Margin="10,0,5,0" Click="btnAdd_Click"/>
            <Button Content="Update" Width="70" Height="28" Margin="5,0,5,0" Click="btnUpdate_Click"/>
            <Button Content="Delete" Width="70" Height="28" Margin="5,0,0,0" Click="btnDelete_Click"/>
        </StackPanel>

        <!-- Sort Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Sort by:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Sort by Date" Width="100" Height="28"
                    Margin="0,0,10,0" Click="btnSortDate_Click"/>
            <Button Content="Sort by Price" Width="100" Height="28"
                    Click="btnSortPrice_Click"/>
        </StackPanel>

        <!-- Books DataGrid -->
        <DataGrid Grid.Row="3" x:Name="dgBooks"
                  Margin="0,0,0,10"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  SelectionChanged="dgBooks_SelectionChanged"/>

        <!-- Student Records Search -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,0,5">
            <TextBlock Text="Search Student Records by Book:"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearchStudent" Width="150" Height="28" Padding="3"/>
            <Button Content="Search" Width="70" Height="28"
                    Margin="10,0,10,0" Click="btnSearchStudent_Click"/>
            <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dpFrom" Width="120" Height="28"/>
            <TextBlock Text="To:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <DatePicker x:Name="dpTo" Width="120" Height="28"/>
            <Button Content="Search Dates" Width="100" Height="28"
                    Margin="10,0,0,0" Click="btnSearchDates_Click"/>
        </StackPanel>

        <!-- Student Records DataGrid -->
        <DataGrid Grid.Row="5" x:Name="dgStudentRecords"
                  Height="180"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

    </Grid>
</Window>